{
  "name": "GalleryImage",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "T\u00edtulo da imagem"
    },
    "image_url": {
      "type": "string",
      "description": "URL da imagem"
    },
    "category": {
      "type": "string",
      "enum": [
        "maquinas",
        "aplicacoes",
        "estrutura",
        "projetos"
      ],
      "default": "maquinas"
    },
    "order": {
      "type": "number",
      "default": 0
    },
    "active": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "image_url"
  ]
}